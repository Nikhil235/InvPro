# ─────────────────────────────────────────────────────────
# XAU/USD Gold Trading Pipeline — Environment Configuration
# ─────────────────────────────────────────────────────────
# Copy this file to `.env` and adjust values as needed.
# All values are OPTIONAL — defaults from config/settings.py
# are used when a key is absent.
#
# Usage:
#   cp .env.example .env
#   notepad .env          # edit values
#   python main.py        # values auto-loaded on startup
# ─────────────────────────────────────────────────────────

# ── Scraping ────────────────────────────────────────────
REFRESH_INTERVAL_SECONDS=5
HEADLESS=true

# ── Strategy ────────────────────────────────────────────
ACCOUNT_BALANCE=10000
RISK_PER_TRADE_PCT=0.01
MIN_REWARD_RISK_RATIO=2.0
ATR_PERIOD=14
ATR_STOP_MULTIPLIER=1.5
LOT_SIZE=100
STRATEGY_EVAL_INTERVAL=30

# ── Logging ─────────────────────────────────────────────
# Options: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
